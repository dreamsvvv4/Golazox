# .env.social — Credenciales para el auto-poster de TikTok
# Copia este archivo a .env.social y rellena los valores.
# O mejor: ponlos en Hostinger hPanel → Node.js → Environment Variables
# NO subas este archivo a git (está en .gitignore)

# ── TikTok ────────────────────────────────────────────────────────────────────
# Obtén estos valores tras completar el OAuth 2.0 flow en developers.tiktok.com
# Instrucciones: https://developers.tiktok.com/doc/login-kit-web

TIKTOK_ACCESS_TOKEN=TU_ACCESS_TOKEN_AQUI
TIKTOK_OPEN_ID=TU_OPEN_ID_AQUI

# ── General ───────────────────────────────────────────────────────────────────
GOLAZOX_URL=https://golazox.com

# ── Control ───────────────────────────────────────────────────────────────────
# 1 = solo genera video, NO sube (para probar que el video queda bien)
# 0 = genera Y sube a TikTok
SOCIAL_DRY_RUN=1
