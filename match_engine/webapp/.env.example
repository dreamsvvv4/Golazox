# ─────────────────────────────────────────────────────
#  GolazOX — Social Media Credentials
#  Copy this file to .env and fill your real values
# ─────────────────────────────────────────────────────

# ── YOUTUBE ──────────────────────────────────────────
# 1. Create project at https://console.cloud.google.com
# 2. Enable "YouTube Data API v3"
# 3. Create OAuth 2.0 Client ID (Desktop app type)
# 4. Run:  node uploader.js --auth youtube
#    Then: node uploader.js --auth-exchange <CODE>
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# ── X / TWITTER ──────────────────────────────────────
# 1. Create app at https://developer.x.com/en/portal/dashboard
# 2. Enable "Read and Write" + "Media Upload" permissions
# 3. Generate Access Token & Secret (User Auth)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# ── META (Instagram + Facebook) ──────────────────────
# 1. Create app at https://developers.facebook.com (type: Business)
# 2. Add products: Instagram Basic Display + Facebook Login
# 3. Get long-lived Page Access Token (60 days, auto-refreshable)
#    → https://developers.facebook.com/tools/explorer
#    Permissions needed: instagram_content_publish, pages_manage_posts, pages_read_engagement
META_ACCESS_TOKEN=

# Instagram: Your IG Business account numeric ID
# → GET https://graph.facebook.com/v21.0/me/accounts?access_token=YOUR_TOKEN
INSTAGRAM_USER_ID=

# Facebook: Your Page numeric ID (same endpoint as above)
FACEBOOK_PAGE_ID=

# Instagram & Facebook Reels require the video on a PUBLIC HTTPS URL.
# Upload your .mp4 to an S3 bucket, Cloudflare R2, Bunny CDN, etc.
# Set this BEFORE uploading, or leave blank to skip IG/FB.
META_VIDEO_CDN_URL=

# ── TIKTOK ───────────────────────────────────────────
# 1. Apply for Content Posting API access at https://developers.tiktok.com
# 2. After approval, get user access token via OAuth flow
# 3. Paste user access token (valid 24h, refresh with TIKTOK_REFRESH_TOKEN)
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=
