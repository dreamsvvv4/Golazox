{
  "name": "football-match-simulator",
  "version": "3.0.0",
  "description": "Probabilistic football match simulator – any team, any era",
  "main": "server.js",
  "scripts": {
    "build": "node _build_assets.js",
    "start": "npx pm2 reload golazox 2>/dev/null || npx pm2 start ecosystem.config.js --env production",
    "start:prod": "NODE_ENV=production node server.js",
    "pm2:start": "npx pm2 start ecosystem.config.js --env production",
    "pm2:reload": "npx pm2 reload golazox",
    "pm2:stop": "npx pm2 stop golazox",
    "pm2:logs": "npx pm2 logs golazox",
    "dev": "node --watch server.js",
    "audit": "node audit_squads.js",
    "audit:verbose": "node audit_squads.js --verbose",
    "audit:full": "node audit_squads.js --check-names --check-clones --verbose",
    "seed": "node seed_squads.js",
    "seed:bg": "node seed_squads_bg.js",
    "seed:dry": "node seed_squads_bg.js --dry-run",
    "seed:once": "node seed_squads_bg.js --once",
    "seed:badges": "node seed_squads_bg.js --badges-only --once"
  },
  "dependencies": {
    "cheerio": "^1.1.0",
    "compression": "^1.8.1",
    "dotenv": "^17.4.1",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.1",
    "express-slow-down": "^3.1.0",
    "ffmpeg-static": "^5.3.0",
    "form-data": "^4.0.5",
    "googleapis": "^171.4.0",
    "mysql2": "^3.11.0",
    "node-fetch": "^2.7.0",
    "nodemailer": "^8.0.4",
    "puppeteer": "^19.11.1",
    "puppeteer-screen-recorder": "^3.0.6",
    "twitter-api-v2": "^1.29.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "jimp": "^0.22.12",
    "pm2": "^6.0.14"
  }
}
